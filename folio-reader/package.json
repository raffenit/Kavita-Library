{
  "name": "folio-app",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:pwa": "expo export --platform web && node scripts/pwa-post-build.js",
    "preview": "npx serve dist --single",
    "preview:proxy": "node scripts/preview-server.js",
    "test": "jest",
    "test:profile": "jest __tests__/profile.test.ts",
    "validate:types": "tsc --noEmit --jsx react-native",
    "validate:jsx": "node scripts/validate-jsx.js",
    "validate:jsx-advanced": "node scripts/validate-jsx-advanced.js",
    "structure:generate": "grep -rn \"^export function\\|^export const.*=.*(\" app/ components/ hooks/ services/ contexts/ constants/ --include=\"*.tsx\" --include=\"*.ts\" | sort > docs/STRUCTURE_AUTO.md"
  },
  "dependencies": {
    "@expo/config-plugins": "~55.0.5",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "^2.1.2",
    "@react-native-community/slider": "5.1.2",
    "@shopify/flash-list": "^2.0.2",
    "axios": "^1.7.2",
    "epubjs": "^0.3.93",
    "expo": "^55.0.11",
    "expo-audio": "^55.0.11",
    "expo-constants": "~55.0.9",
    "expo-file-system": "~55.0.12",
    "expo-font": "~55.0.4",
    "expo-image-picker": "~16.1.4",
    "expo-linking": "~55.0.9",
    "expo-router": "~55.0.8",
    "expo-secure-store": "~55.0.9",
    "expo-status-bar": "~55.0.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-native": "^0.83.4",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-pdf": "6.7.3",
    "react-native-reanimated": "^4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "^0.21.2",
    "react-native-web-webview": "^1.0.2",
    "react-native-webview": "^13.16.0",
    "react-native-worklets": "^0.8.1"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/react": "~19.2.10",
    "@types/react-native": "^0.72.8",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.15",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.2"
  },
  "private": true
}
